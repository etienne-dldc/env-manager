{
  "name": "env-manager",
  "exports": "./main.tsx",
  "version": "0.1.0",
  "tasks": {
    "bump": "deno run -A jsr:@mys/bump@1",
    "deps:outdated": "deno outdated",
    "deps:update": "deno outdated --update --latest --interactive",
    "start": "deno run --allow-net --allow-env --allow-read=/app,/data --allow-write=/data --allow-run=curl --no-prompt main.tsx",
    "dev": "ENV_FOLDER=./.data/env ENV_TEMPLATE_FOLDER=./.data/env-template deno run --allow-net --allow-env --allow-read=. --allow-write=./.data --allow-run=curl --no-prompt --watch main.tsx",
    "test:run": "deno test --allow-all"
  },
  "imports": {
    "@dldc/hono-ui": "jsr:@dldc/hono-ui@^1.7.0",
    "@hono/hono": "jsr:@hono/hono@^4.12.15",
    "@opentelemetry/api": "npm:@opentelemetry/api@^1.9.1",
    "@std/expect": "jsr:@std/expect@^1.0.19",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@valibot/valibot": "jsr:@valibot/valibot@^1.3.1",
    "hono": "jsr:@hono/hono@^4.12.14",
    "lucide-static": "npm:lucide-static@^1.14.0"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx"
  }
}
